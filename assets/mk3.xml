<!-- This version has a nearly weightless pole with a mass at the end. This is better resembles the problem definition of the Cart Pole Prolbem found in https://underactuated.csail.mit.edu/acrobot.html#cart_pole -->
<mujoco model="inverted two-axis pendulum">
  <compiler inertiafromgeom="true"/>
  <default>
    <joint damping="0" limited="true"/>
    <!-- <geom contype="0" friction="1 0.1 0.1" rgba="0.4 0.33 0.26 1.0"/> -->
    <motor ctrlrange="-1 1"/>
  </default>
  <option gravity="0 0 -9.81" />
  <custom>
    <numeric data="10000" name="constraint_stiffness"/>
    <numeric data="10000" name="constraint_limit_stiffness"/>
    <numeric data="0" name="spring_mass_scale"/>
    <numeric data="1" name="spring_inertia_scale"/>
    <numeric data="5" name="solver_maxls"/>
  </custom>
  <size nstack="3000"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.8 0.8 0.8" rgb2="0 0 0" width="512" height="3072"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="100" height="100" />
    <material name="floor_material" texture="floor_tex" texuniform="true" />
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.2" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" material="floor_material" name="floor" pos="0 0 -0.75" size="40 40 40" type="plane" rgba="0.5 0.5 0.5 1.0"/>    
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>

    <geom pos="0 10.2 0" quat="0.707 0 0.707 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/> 
    <geom pos="0 -10.2 0" quat="0.707 0 0.707 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/> 
    <geom pos="10.2 0 0" quat="0.707 0.707 0 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>
    <geom pos="-10.2 0 0" quat="0.707 0.707 0 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>


    <body name="cart" pos="0 0 0">
      <joint axis="1 0 0" limited="true" name="x_slider" pos="0 0 0" range="-5 5" type="slide"/>
      <joint axis="0 1 0" limited="true" name="y_slider" pos="0 0 0" range="-5 5" type="slide"/>
      <geom name="cart" pos="0 0 0" quat="0.707 0 0.707 0" size="0.1 0.1 0.1" type="box" mass="1"/>

      <body name="pole" pos="0 0 0">
        <joint name="pole_joint" type="ball" limited="false" />
        <geom fromto="0 0 0 0 0 0.6" name="pole"  size="0.02" type="capsule" mass="1e-5"/>

        <geom name="mass" type="sphere" size="0.05" pos="0 0 0.6" mass="0.333"/>
        <site name="mass_site" pos="0 0 0.6" size="0.02" rgba="1 0 0 1"/> 
      </body>
    </body>
  </worldbody>
  
  <actuator>
  <motor ctrllimited="true" ctrlrange="-1 1" gear="100" joint="x_slider" name="x_slide"/>
  <motor ctrllimited="true" ctrlrange="-1 1" gear="100" joint="y_slider" name="y_slide"/>
  </actuator>


<sensor>
  <jointpos name="x_pos" joint="x_slider"/>
  <jointpos name="y_pos" joint="y_slider"/>
  <!-- <jointpos name="hinge_x_pos" joint="hinge_x"/>
  <jointpos name="hinge_y_pos" joint="hinge_y"/> -->

  <jointvel name="x_vel" joint="x_slider"/>
  <jointvel name="y_vel" joint="y_slider"/>
  <!-- <jointvel name="hinge_x_vel" joint="hinge_x"/>
  <jointvel name="hinge_y_vel" joint="hinge_y"/> -->

  <actuatorfrc name="x_force" actuator="x_slide"/>
  <actuatorfrc name="y_force" actuator="y_slide"/>

  <framepos name="mass_pos" objtype="site" objname="mass_site"/>
  <framelinvel name="mas_vel" objtype="site" objname="mass_site"/>

</sensor>


</mujoco>
